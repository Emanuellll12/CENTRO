                } else {
                    console.warn('⚠️ Caixa encontrado como ABERTO mas re-check diz:', caixaCompleto?.status);
                    caixaAtual = null;
                    atualizarBotaoCaixa(false);
                }
            } catch (error) {
                console.error('❌ Erro ao verificar caixa:', error);
            }
        }

