        function selecionarImpressora(nome, el) {
            document.getElementById('inputNomeImpressora').value = nome;
            // Highlight visual na lista
            document.querySelectorAll('#listaImpressorasConfig > div').forEach(d => {
                d.style.background = '';
                d.style.fontWeight = '';
                d.style.color = '#333';
            });
            el.style.background = '#f0e8f8';
            el.style.fontWeight = '700';
            el.style.color = '#6c059b';
