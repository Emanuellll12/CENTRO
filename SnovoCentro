                        <p>Nenhum produto cadastrado</p>
                    </div>
                `;
                return;
            }

            let html = '';

            categorias.forEach(categoria => {
                let produtosCategoria;
                
                if (categoria === 'Sorvetes') {
                    // Produtos que começam com "X" são sorvetes
                    produtosCategoria = produtos.filter(p => p.codigo.toUpperCase().startsWith('X'));
                } else {
                    // Demais produtos vão para suas categorias normais (exceto os que começam com X)
                    produtosCategoria = produtos.filter(p => 
                        p.categoria === categoria && !p.codigo.toUpperCase().startsWith('X')
                    );
