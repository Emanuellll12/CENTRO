                        const btn = document.getElementById('mdBtnOk');
                        if (!btn.disabled) btn.click();
                    }
                    if (e.key === 'Escape') {
                        document.getElementById('modalDinheiro').classList.remove('active');
                        resolve({ cancelado: true });
                    }
                };
                // botão cancelar
                document.querySelector('.modal-dinheiro-btn-cancel').onclick = () => {
                    document.getElementById('modalDinheiro').classList.remove('active');
                    resolve({ cancelado: true });
                };
            });
        }

        let _dividido_parcelaAtual = 0;
        let _dividido_totalParcelas = 0;

        async function finalizarPagamentoDividido() {
            const valorTotal = parseFloat(getValorTotal());
            const valorPago = parcelasDivididas.reduce((sum, p) => sum + (parseFloat(p.valor) || 0), 0);
            const diferenca = Math.abs(valorTotal - valorPago);

            if (diferenca > 0.01) {
                if (valorPago < valorTotal) {
                    alert(`❌ VALOR INSUFICIENTE!\n\nTotal: R$ ${valorTotal.toFixed(2)}\nPago: R$ ${valorPago.toFixed(2)}\nFalta: R$ ${(valorTotal - valorPago).toFixed(2)}`);
                } else {
                    alert(`❌ VALOR EXCEDENTE!\n\nTotal: R$ ${valorTotal.toFixed(2)}\nPago: R$ ${valorPago.toFixed(2)}\nExcedente: R$ ${(valorPago - valorTotal).toFixed(2)}`);
                }
                return;
            }
            if (parcelasDivididas.length === 0) {
                alert('❌ Adicione pelo menos uma forma de pagamento!');
                return;
            }

            // Fecha o modal dividido para dar espaço aos popups
            document.getElementById('modalDividido').classList.remove('active');

            _dividido_totalParcelas = parcelasDivididas.length;
            const pagamentosProcessados = [];

            for (let i = 0; i < parcelasDivididas.length; i++) {
                const parcela = parcelasDivididas[i];
                _dividido_parcelaAtual = i + 1;
                const valorParcela = parseFloat(parcela.valor);
                let resultado = null;

                console.log(`\n--- Parcela ${_dividido_parcelaAtual}/${_dividido_totalParcelas}: ${parcela.metodo} R$ ${valorParcela.toFixed(2)} ---`);

                if (parcela.metodo === 'PIX') {
                    // PIX: registra direto sem maquininha (igual ao fluxo normal)
                    resultado = { metodo: 'PIX', valor: valorParcela, sucesso: true };

                } else if (parcela.metodo === 'DEBITO' || parcela.metodo === 'CREDITO') {
                    // CRED/DEB: usa popup TEF com botão finalizar manualmente
                    const res = await _aguardarPopupTEFDividido(parcela.metodo, valorParcela);

                    if (res.cancelado) {
                        alert('❌ Pagamento cancelado.\n\nOs itens permanecem no carrinho.');
                        // Reabre modal dividido
                        document.getElementById('modalDividido').classList.add('active');
                        return;
                    }
                    resultado = {
                        metodo: parcela.metodo,
                        valor: valorParcela,
                        autorizacao: res.manual ? 'MANUAL' : res.autorizacao,
                        nsu:      res.manual ? null : res.nsu,
                        bandeira: res.manual ? null : res.bandeira,
                        parcelas: res.manual ? 1    : res.parcelas,
                        manual:   !!res.manual,
                        sucesso: true
                    };

                } else if (parcela.metodo === 'DINHEIRO') {
                    // DINHEIRO: usa modal com troco em tempo real + abre gaveta
                    const res = await _aguardarModalDinheiroDividido(valorParcela);

                    if (res.cancelado) {
                        alert('❌ Pagamento cancelado.\n\nOs itens permanecem no carrinho.');
                        document.getElementById('modalDividido').classList.add('active');
                        return;
                    }
                    resultado = {
                        metodo: 'DINHEIRO',
                        valor: valorParcela,
                        valor_recebido: res.valorRecebido,
                        troco: res.troco,
                        sucesso: true
                    };
                }

                if (resultado && resultado.sucesso) {
                    pagamentosProcessados.push(resultado);
                    console.log(`✅ Parcela ${_dividido_parcelaAtual} OK`);
                }
            }

            // Todas as parcelas OK — registra a venda
            try {
                const observacao = pagamentosProcessados.map(p =>
                    `${p.metodo}: R$ ${parseFloat(p.valor).toFixed(2)}${p.manual ? ' (MANUAL)' : p.autorizacao ? ' (Auth: ' + p.autorizacao + ')' : ''}`
                ).join(' | ');

                const resultadoVenda = await registrarVenda('DIVIDIDO', {
                    pagamento_dividido: true,
                    formas_pagamento: pagamentosProcessados,
                    observacao_pagamento: observacao
                });

                if (!resultadoVenda || !resultadoVenda.sucesso) {
                    alert('❌ Erro ao registrar venda no sistema!\n\nATENÇÃO: Os pagamentos foram processados mas a venda não foi registrada.');
                    return;
                }

                limparCarrinho(true);
                fecharPagamentoDividido();
                showVendaSucesso(`DIVIDIDO • Cód. ${resultadoVenda.codigo_venda}`);

            } catch (error) {
                console.error('❌ Erro ao finalizar pagamento dividido:', error);
                alert('❌ Erro ao processar pagamento dividido:\n\n' + error.message);
            }
        }

