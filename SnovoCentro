                if (produtosCategoria.length === 0) return;

                const corClasse = categoria.toLowerCase();
                const favs = getFavoritos();
                // Favoritos sobem para o topo dentro da categoria
                const ordenados = [
                    ...produtosCategoria.filter(p => favs.includes(p.codigo)),
                    ...produtosCategoria.filter(p => !favs.includes(p.codigo))
                ];
                
