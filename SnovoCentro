                console.log(`⭐ ${favoritosCache.length} favoritos carregados.`);
            } catch (e) {
                console.warn('Erro ao carregar favoritos:', e);
                favoritosCache = [];
            }
        }

        async function toggleFavorito(codigo, lojaId) {
            const isFav = favoritosCache.includes(codigo);

            // 1. Atualiza cache e UI imediatamente (sem esperar Supabase)
            if (isFav) favoritosCache = favoritosCache.filter(c => c !== codigo);
            else favoritosCache.push(codigo);
            renderizarCategorias(produtosTodos);

            // 2. Persiste no Supabase
            try {
                let erro = null;
                if (isFav) {
                    const res = await supabaseClient
                        .from('produtos_favoritos')
                        .delete()
                        .eq('loja_id', lojaId)
                        .eq('codigo', codigo);
                    erro = res.error;
                } else {
                    const res = await supabaseClient
                        .from('produtos_favoritos')
                        .insert({ loja_id: lojaId, codigo: codigo });
                    // Se der conflito (já existe), ignora — está salvo
                    if (res.error && res.error.code !== '23505') erro = res.error;
                }

                if (erro) throw erro;
                console.log(`⭐ Supabase: favorito ${isFav ? 'removido' : 'salvo'} — ${codigo}`);

            } catch (e) {
                console.error('❌ Erro ao salvar favorito no Supabase:', e);
                // Reverte cache
                if (isFav) favoritosCache.push(codigo);
                else favoritosCache = favoritosCache.filter(c => c !== codigo);
                renderizarCategorias(produtosTodos);

                const msg = e?.message || e?.code || JSON.stringify(e);
                if (msg.includes('does not exist') || msg.includes('relation')) {
                    alert('❌ Tabela produtos_favoritos não existe no Supabase!\n\nRode este SQL no Supabase SQL Editor:\n\nCREATE TABLE produtos_favoritos (\n  id bigserial primary key,\n  loja_id text not null,\n  codigo text not null,\n  unique(loja_id, codigo)\n);\n\nALTER TABLE produtos_favoritos ENABLE ROW LEVEL SECURITY;\nCREATE POLICY \"allow_all\" ON produtos_favoritos FOR ALL USING (true) WITH CHECK (true);');
                } else {
                    alert('❌ Erro ao salvar favorito:\n' + msg);
                }
            }
        }

        function renderizarCategorias(produtos) {
            console.log('Renderizando categorias com', produtos.length, 'produtos');
            const categorias = ['Sorvetes', 'Bebidas', 'Salgados', 'Combos', 'Outros'];
