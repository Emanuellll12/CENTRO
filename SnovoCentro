            try {
                // Busca TODOS os caixas ABERTOS desta loja (detectar fantasmas)
                const { data: caixasAbertos, error: errAbertos } = await supabaseClient
                    .from('caixas')
                    .select('id, status, data_abertura, data_fechamento')
                    .eq('loja_id', lojaAtual.id)
                    .eq('status', 'ABERTO')
                    .order('data_abertura', { ascending: false });

                console.log('📋 Caixas ABERTOS encontrados:', JSON.stringify(caixasAbertos, null, 2));

                if (!caixasAbertos || caixasAbertos.length === 0) {
                    console.log('❌ Nenhum caixa aberto encontrado para loja:', lojaAtual.id);
                    caixaAtual = null;
                    atualizarBotaoCaixa(false);
                    return;
                }

                // Se tem mais de 1 caixa aberto, fechar os antigos (fantasmas)
                if (caixasAbertos.length > 1) {
                    console.warn(`⚠️ ENCONTRADOS ${caixasAbertos.length} CAIXAS ABERTOS! Fechando fantasmas...`);
                    const fantasmas = caixasAbertos.slice(1); // todos menos o mais recente
                    for (const fantasma of fantasmas) {
                        console.warn('🧹 Fechando caixa fantasma ID:', fantasma.id, '| Abertura:', fantasma.data_abertura);
                        await supabaseClient
                            .from('caixas')
                            .update({
                                status: 'FECHADO',
                                data_fechamento: new Date().toISOString(),
                                observacao_fechamento: 'FECHADO AUTOMATICAMENTE - caixa fantasma detectado'
                            })
                            .eq('id', fantasma.id);
                    }
                }

                // Pegar o mais recente (que sobrou)
                const maisRecente = caixasAbertos[0];

                // CONFERÊNCIA EXTRA: buscar este caixa completo de novo pelo ID
                const { data: caixaCompleto } = await supabaseClient
                    .from('caixas')
                    .select('*')
                    .eq('id', maisRecente.id)
                    .single();

                console.log('🔄 Re-check do caixa:', caixaCompleto?.id, '| Status:', caixaCompleto?.status);

                if (caixaCompleto && caixaCompleto.status === 'ABERTO') {
