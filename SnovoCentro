        // ==================== CARRINHO DE COMPRAS ====================
        // ==================== BALANÇA (códigos 0–50) ====================
        let _balancaProduto = null;

        function isProdutoBalanca(produto) {
            const cod = parseInt(produto.codigo, 10);
            return !isNaN(cod) && cod >= 0 && cod <= 50;
        }

        function adicionarAoCarrinho(produto) {
            console.log('Adicionando ao carrinho:', produto);
            if (isProdutoBalanca(produto)) {
                abrirModalBalanca(produto);
                return;
            }
            if (produto.estoque <= 0) {
                alert(`❌ Produto sem estoque! Não é possível adicionar ao carrinho.`);
                return;
            }
            const itemExistente = carrinho.find(item => item.codigo === produto.codigo);
            if (itemExistente) {
                if (itemExistente.quantidade >= produto.estoque) {
                    alert(`Estoque insuficiente! Disponível: ${produto.estoque}`);
                    return;
                }
                itemExistente.quantidade++;
            } else {
                carrinho.push({
                    codigo: produto.codigo,
                    nome: produto.nome,
                    preco: parseFloat(produto.preco_venda),
                    quantidade: 1,
                    estoque: produto.estoque,
                    balanca: false
                });
            }
            atualizarCarrinho();
        }

        function abrirModalBalanca(produto) {
            _balancaProduto = produto;
            document.getElementById('balancaNome').textContent = produto.nome;
            document.getElementById('balancaPrecoKg').textContent =
                `R$ ${parseFloat(produto.preco_venda).toFixed(2)} / kg`;
            document.getElementById('balancaGramas').value = '';
            document.getElementById('balancaPreview').textContent = '';
            document.getElementById('modalBalanca').classList.add('active');
            setTimeout(() => document.getElementById('balancaGramas').focus(), 100);
        }

        function fecharModalBalanca() {
            document.getElementById('modalBalanca').classList.remove('active');
            _balancaProduto = null;
        }

        function calcularBalanca() {
            const g = parseFloat(document.getElementById('balancaGramas').value);
            const prev = document.getElementById('balancaPreview');
            if (!_balancaProduto || isNaN(g) || g <= 0) {
                prev.textContent = '';
                return;
            }
            const precoKg = parseFloat(_balancaProduto.preco_venda);
            const valor = (precoKg * g) / 1000;
            prev.textContent = `R$ ${valor.toFixed(2).replace('.', ',')}`;
        }

        function balancaKeyDown(e) {
            if (e.key === 'Enter') confirmarBalanca();
            if (e.key === 'Escape') fecharModalBalanca();
        }

        function confirmarBalanca() {
            const g = parseFloat(document.getElementById('balancaGramas').value);
            if (!_balancaProduto || isNaN(g) || g <= 0) {
                document.getElementById('balancaGramas').focus();
                return;
            }
            const precoKg = parseFloat(_balancaProduto.preco_venda);
            const precoItem = parseFloat(((precoKg * g) / 1000).toFixed(2));
            const label = g >= 1000
                ? `${(g / 1000).toFixed(3).replace('.', ',')} kg`
                : `${g}g`;

            // Balança sempre adiciona como nova linha (cada pesagem é única)
            carrinho.push({
                codigo: _balancaProduto.codigo,
                nome: `${_balancaProduto.nome} (${label})`,
                preco: precoItem,
                quantidade: 1,
                estoque: _balancaProduto.estoque,
                balanca: true,
                gramas: g
            });

            fecharModalBalanca();
            atualizarCarrinho();
        }

        function removerDoCarrinho(index) {
            carrinho.splice(index, 1);
            atualizarCarrinho();
        }

        function alterarQuantidade(index, delta) {
            const item = carrinho[index];
            const novaQuantidade = item.quantidade + delta;

            if (novaQuantidade <= 0) {
                removerDoCarrinho(index);
                return;
            }

            if (novaQuantidade > item.estoque) {
                alert(`Estoque insuficiente! Disponível: ${item.estoque}`);
                return;
            }

            item.quantidade = novaQuantidade;
            atualizarCarrinho();
        }

        function atualizarCarrinho() {
            console.log('Atualizando carrinho. Total de itens:', carrinho.length);
            const carrinhoTable = document.getElementById('carrinhoTable');
            const carrinhoTotalDiv = document.getElementById('carrinhoTotalDiv');
            
            if (carrinho.length === 0) {
                carrinhoTable.innerHTML = `
                    <div class="carrinho-empty">
                        <div class="carrinho-empty-icon">🛒</div>
                        <p>Carrinho vazio</p>
                    </div>
                `;
                carrinhoTotalDiv.style.display = 'none';
                return;
            }

            let html = `
                <table>
                    <thead>
                        <tr>
                            <th>Produto</th>
                            <th>Qtd</th>
                            <th>Preço</th>
                            <th>Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
            `;

            let total = 0;

            carrinho.forEach((item, index) => {
                const subtotal = item.preco * item.quantidade;
                total += subtotal;

                const qtdCell = item.balanca
                    ? `<span style="color:#a855f7;font-size:13px;">⚖️ ${item.gramas}g</span>`
                    : `<div class="qtd-controls">
                        <button class="qtd-btn" onclick="alterarQuantidade(${index}, -1)">−</button>
                        <span class="qtd-numero">${item.quantidade}</span>
                        <button class="qtd-btn" onclick="alterarQuantidade(${index}, 1)">+</button>
                       </div>`;

                html += `
                    <tr>
                        <td><strong>${item.nome}</strong><br><small style="color: #6b7280;">Cód: ${item.codigo}</small></td>
                        <td>${qtdCell}</td>
                        <td>R$ ${parseFloat(item.preco).toFixed(2)}</td>
                        <td>R$ ${subtotal.toFixed(2)}</td>
                    </tr>
                `;
            });

            html += `
                    </tbody>
                </table>
            `;

            carrinhoTable.innerHTML = html;
            carrinhoTotalDiv.style.display = 'block';
            document.getElementById('totalValor').textContent = `R$ ${total.toFixed(2).replace('.', ',')}`;
            console.log('Carrinho atualizado. Total:', total);
        }

        function limparCarrinho(semConfirmacao = false) {
            if (carrinho.length === 0) return;
            
            if (semConfirmacao || confirm('Deseja limpar o carrinho?')) {
                carrinho = [];
                atualizarCarrinho();
            }
        }

        function getValorTotal() {
            return carrinho.reduce((total, item) => total + (item.preco * item.quantidade), 0).toFixed(2);
        }

        // ==================== REGISTRAR VENDA NO SUPABASE ====================
        async function registrarVenda(tipoPagamento, dadosTEF) {
            if (carrinho.length === 0) return;

            try {
                const valorTotal = parseFloat(getValorTotal());
                const quantidadeItens = carrinho.reduce((total, item) => total + item.quantidade, 0);
                
                console.log('=== INICIANDO REGISTRO DE VENDA ===');
                console.log('Loja:', lojaAtual.nome, '(', lojaAtual.id, ')');
                console.log('Método:', tipoPagamento);
                console.log('Valor Total:', valorTotal);
                console.log('Quantidade de Itens:', quantidadeItens);
                console.log('Produtos:', carrinho);
                
                // 1. INSERIR VENDA NA TABELA VENDAS
                const agora = new Date().toISOString();
                const vendaData = {
                    loja_id: lojaAtual.id,
                    data_hora: agora,
                    data_venda: agora,
                    valor_total: valorTotal,
                    metodo_pagamento: tipoPagamento,
                    quantidade_itens: quantidadeItens,
                    status: 'CONCLUIDA',
                    usuario: usuarioAtual.email,
                    nsu_tef: dadosTEF?.nsu || null,
                    chave_tef: dadosTEF?.chave || null,
                    observacao: `Venda realizada via ${tipoPagamento} - Loja: ${lojaAtual.nome}`
                };
                
                const { data: vendaRegistrada, error: vendaError } = await supabaseClient
                    .from('vendas')
                    .insert([vendaData])
                    .select()
                    .single();
                
                if (vendaError) {
                    console.error('❌ Erro ao registrar venda:', vendaError);
                    throw vendaError;
                }
                
                console.log('✅ Venda registrada com ID:', vendaRegistrada.id);
                
                // 2. INSERIR ITENS DA VENDA NA TABELA ITENS_VENDA
                const itensVenda = carrinho.map(item => ({
                    loja_id: lojaAtual.id,
                    venda_id: vendaRegistrada.id,
                    codigo_produto: String(item.codigo),
                    nome_produto: item.nome,
                    quantidade: item.quantidade,
                    preco_unitario: parseFloat(item.preco),
                    subtotal: parseFloat(item.preco) * item.quantidade,
                    data_registro: agora
                }));
                
                const { error: itensError } = await supabaseClient
                    .from('itens_venda')
                    .insert(itensVenda);
                
                if (itensError) {
                    console.error('❌ Erro ao registrar itens da venda:', itensError);
                    throw itensError;
                }
                
                console.log('✅ Itens da venda registrados:', itensVenda.length, 'produtos');
                
                // 3. ATUALIZAR ESTOQUE E REGISTRAR MOVIMENTAÇÕES
                for (const item of carrinho) {
                    console.log(`Atualizando estoque do produto ${item.codigo}...`);
                    
                    // Buscar estoque atual
                    const { data: itemAtual, error: fetchError } = await supabaseClient
                        .from('itens')
                        .select('estoque')
                        .eq('codigo', item.codigo)
                        .eq('loja_id', lojaAtual.id) // Filtro por loja
                        .single();

                    if (fetchError) {
                        console.error('❌ Erro ao buscar estoque:', fetchError);
                        continue;
                    }

                    const novoEstoque = itemAtual.estoque - item.quantidade;

                    // Atualizar estoque
                    const { error: estoqueError } = await supabaseClient
                        .from('itens')
                        .update({ estoque: novoEstoque })
                        .eq('codigo', item.codigo)
                        .eq('loja_id', lojaAtual.id); // Filtro por loja

                    if (estoqueError) {
                        console.error('❌ Erro ao atualizar estoque:', estoqueError);
                    } else {
                        console.log(`✅ Estoque atualizado: ${item.codigo} (${itemAtual.estoque} → ${novoEstoque})`);
                    }

                    // Registrar movimentação
                    const { error: movError } = await supabaseClient
                        .from('movimentacoes')
                        .insert([{
                            loja_id: lojaAtual.id,
                            item_codigo: String(item.codigo),
                            tipo: 'VENDA',
                            quantidade: -item.quantidade,
                            valor_unitario: item.preco,
                            responsavel: usuarioAtual.email,
                            observacao: `Venda #${vendaRegistrada.id} - ${tipoPagamento}`
                        }]);

                    if (movError) {
                        console.error('❌ Erro ao registrar movimentação:', movError);
                    } else {
                        console.log(`✅ Movimentação registrada: ${item.codigo}`);
                    }
                }
                
                console.log('=== VENDA COMPLETAMENTE REGISTRADA ===');
                console.log('ID da Venda:', vendaRegistrada.id);
                console.log('Total Produtos:', itensVenda.length);
                console.log('Valor Total:', valorTotal);
                
                // Verificar se vendeu sorvete e notificar
                console.log('=== VERIFICANDO SORVETES NO CARRINHO ===');
                console.log('Itens no carrinho:', carrinho);
                
                const sorvetes = carrinho.filter(item => {
                    const codigoUpper = String(item.codigo).toUpperCase();
                    const isSorvete = codigoUpper.startsWith('X');
                    console.log(`Item: ${item.nome} (${item.codigo}) - É sorvete? ${isSorvete}`);
                    return isSorvete;
                });
                
                console.log('Sorvetes encontrados:', sorvetes.length);
                
                if (sorvetes.length > 0) {
                    console.log('🍦 Venda contém sorvete - enviando notificação...');
                    try {
                        await notificarVendaSorvete(carrinho, vendaRegistrada.id, valorTotal);
                        console.log('✅ Notificação de sorvete enviada');
                    } catch (error) {
                        console.error('❌ Erro ao enviar notificação de sorvete:', error);
                    }
                } else {
                    console.log('ℹ️ Nenhum sorvete na venda - não enviará notificação');
                }
                
                // Retornar no formato esperado pelas funções de finalização
                return {
                    sucesso: true,
                    codigo_venda: vendaRegistrada.id,
                    venda: vendaRegistrada
                };
                
            } catch (error) {
                console.error('❌ ERRO GERAL ao registrar venda:', error);
                return {
                    sucesso: false,
                    erro: error.message
                };
            }
        }

