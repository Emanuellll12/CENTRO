            if (isNaN(qtdReposicao) || qtdReposicao <= 0) {
                alert('❌ Quantidade inválida! Digite um número positivo.');
                return;
            }

            try {
                const novoEstoque = produto.estoque + qtdReposicao;

                console.log(`Atualizando estoque: ${produto.estoque} → ${novoEstoque}`);

                // 1. Atualizar estoque no banco
