                        throw err2;
                    }

                    // Verificar a segunda tentativa
                    const { data: recheck2 } = await supabaseClient
                        .from('caixas')
                        .select('id, status')
                        .eq('id', caixaId)
                        .single();

                    if (!recheck2 || recheck2.status !== 'FECHADO') {
                        alert('❌ ERRO CRÍTICO: Mesmo após 2 tentativas, o caixa NÃO fechou no banco.\n\nContate o suporte técnico IMEDIATAMENTE.');
                        return;
                    }
                    console.log('✅ Caixa fechado na segunda tentativa');
                } else {
                    console.log('✅ Caixa fechado com sucesso no banco. ID:', caixaId);
                }

                // Buscar vendas do dia para o relatório
                const hoje = hojeBrasilia();
                const { data: vendasDia } = await supabaseClient
                    .from('vendas')
                    .select('id, valor_total, metodo_pagamento, data_venda, status, itens_venda(nome_produto, quantidade, preco_unitario)')
                    .eq('loja_id', lojaAtual.id)
                    .gte('data_venda', inicioDiaBrasilia(hoje))
                    .lte('data_venda', fimDiaBrasilia(hoje))
                    .order('data_venda', { ascending: true });

                fecharModalFechamento();

                await notificarAcaoCaixa('FECHAR', {
                    valorInicial:   d.saldoInicial,
                    valorFinal:     d.valorContado,
                    valorVendas:    d.totalGeral,
                    qtdVendas:      d.qtdVendas,
                    totalRetiradas: d.totalRetiradas,
                    diferenca:      d.diferenca,
                    totalPix:       d.totalPix,
                    totalCredito:   d.totalCredito,
                    totalDebito:    d.totalDebito,
                    totalDinheiro:  d.totalDinheiro
                });

                // Gerar e enviar relatório HTML pro Telegram
                await enviarRelatorioHTMLTelegram(vendasDia || [], d);

                caixaAtual = null;
                atualizarBotaoCaixa(false);
                showVendaSucesso('Caixa fechado com sucesso!');

            } catch (error) {
                console.error('Erro ao fechar caixa:', error);
                alert('❌ Erro ao fechar caixa: ' + error.message);
            }
        }

// ==================== RELATÓRIO HTML AO FECHAR CAIXA ====================
        // MODIFICADO: agora agrupa produtos por quantidade (igual financeiro.html)
        async function enviarRelatorioHTMLTelegram(vendas, dados) {
            const fmt = v => `R$ ${v.toFixed(2).replace('.', ',')}`;
            const agora = new Date().toLocaleString('pt-BR', { timeZone: 'America/Sao_Paulo' });
            const hoje = new Date().toLocaleDateString('pt-BR', { timeZone: 'America/Sao_Paulo' });

