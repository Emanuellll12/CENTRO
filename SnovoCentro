        async function mfcCalcular() {
            const inputVal = document.getElementById('mfcValorContado').value;
            const valorContado = parseFloat(String(inputVal).replace(',', '.'));
            if (isNaN(valorContado) || valorContado < 0) {
                document.getElementById('mfcValorContado').focus();
                return;
            }

            // Buscar vendas do caixa
            const { data: vendas } = await supabaseClient
                .from('vendas')
                .select('valor_total, metodo_pagamento')
                .eq('loja_id', lojaAtual.id)
                .gte('data_venda', caixaAtual.data_abertura)
                .eq('status', 'CONCLUIDA');

            const { data: retiradas } = await supabaseClient
                .from('retiradas_caixa')
                .select('valor')
                .eq('caixa_id', caixaAtual.id);

            let totalGeral = 0, totalPix = 0, totalCredito = 0, totalDebito = 0, totalDinheiro = 0;
            (vendas || []).forEach(v => {
                const val = parseFloat(v.valor_total);
                totalGeral += val;
                if (v.metodo_pagamento === 'PIX')      totalPix      += val;
                if (v.metodo_pagamento === 'CREDITO')  totalCredito  += val;
                if (v.metodo_pagamento === 'DEBITO')   totalDebito   += val;
                if (v.metodo_pagamento === 'DINHEIRO') totalDinheiro += val;
            });
            const totalRetiradas = (retiradas || []).reduce((s, r) => s + parseFloat(r.valor), 0);
            const saldoInicial   = parseFloat(caixaAtual.valor_inicial);
            const esperado       = saldoInicial + totalDinheiro - totalRetiradas;
            const diferenca      = valorContado - esperado;

            // Salva para usar na confirmação
            _mfcDados = {
                valorContado, totalGeral, totalPix, totalCredito, totalDebito,
                totalDinheiro, totalRetiradas, saldoInicial, esperado, diferenca,
                qtdVendas: (vendas || []).length
            };

            // Preenche resultado — mostra APENAS dinheiro
            const fmt = v => `R$ ${v.toFixed(2).replace('.', ',')}`;
            document.getElementById('mfcSaldoInicial').textContent     = fmt(saldoInicial);
            document.getElementById('mfcVendasDinheiro').textContent   = fmt(totalDinheiro);
            document.getElementById('mfcRetiradas').textContent        = fmt(totalRetiradas);
            document.getElementById('mfcEsperado').textContent         = fmt(esperado);
            document.getElementById('mfcContado').textContent          = fmt(valorContado);

            const difEl = document.getElementById('mfcDiferenca');
            if (diferenca > 0.009) {
                difEl.textContent  = `+${fmt(diferenca)} (sobra)`;
                difEl.className    = 'mfc-linha-valor mfc-quebra-pos';
            } else if (diferenca < -0.009) {
                difEl.textContent  = `${fmt(diferenca)} (falta)`;
                difEl.className    = 'mfc-linha-valor mfc-quebra-neg';
            } else {
                difEl.textContent  = '✅ Bateu certinho!';
                difEl.className    = 'mfc-linha-valor mfc-quebra-zero';
            }

            // Mostra resultado e botão confirmar
            document.getElementById('mfcStepInput').style.display   = 'none';
            document.getElementById('mfcResultado').style.display   = 'block';
            document.getElementById('mfcBtnsConfirmar').style.display = 'flex';
        }

