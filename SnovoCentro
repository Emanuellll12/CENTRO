                    `Produto: ${produto.nome}\n` +
                    `Quantidade adicionada: ${qtdReposicao}\n` +
                    `Estoque anterior: ${produto.estoque}\n` +
                    `Estoque novo: ${novoEstoque}\n\n` +
                    `📱 Notificação enviada ao Telegram!`
                );

            } catch (error) {
                console.error('❌ Erro ao repor estoque:', error);
                alert('❌ Erro ao repor estoque:\n\n' + error.message);
            }
        }

