        // ==================== NORMALIZAÇÃO DE RESPOSTA ====================
        // Converte o retorno do PlugPag para o formato {resultado: {tef: {...}}}
        // que o restante do VENDAS.HTML já conhece e usa para aprovar vendas.
        function _normalizarRespostaPagBank(data) {
            if (!data) return null;

            // Se aprovado, monta estrutura compatível com resultado.resultado.tef.codigoAutorizacao
            if (data.aprovado && data.autorizacao) {
                return {
                    resultado: {
                        tef: {
                            codigoAutorizacao:  data.autorizacao,
                            codigoBandeira:     data.bandeira    || '',
                            mensagemResultado:  data.mensagem    || 'Aprovado',
                            numeroParcelas:     1,
                            nsu:                data.nsu         || '',
                        }
                    }
                };
            }

            // Negado — retorna sem codigoAutorizacao para que o sistema rejeite
            return {
                resultado: {
                    tef: {
                        mensagemResultado: data.mensagem || 'Transação não aprovada',
                    }
                }
            };
        }

        // Fechar modal clicando fora (aguarda DOM completo)
        document.addEventListener('DOMContentLoaded', function() {
            const modalCI = document.getElementById('modalConfigImpressora');
            if (modalCI) modalCI.addEventListener('click', function(e) {
                if (e.target === this) fecharConfigImpressora();
            });
        });

        // ==================== INTEGRAÇÃO COM FLUXO DE VENDAS ====================
        // Intercepta cada finalização bem-sucedida para salvar dados da última venda.
        // Funciona envolvendo registrarVenda e capturando o retorno.

        const _registrarVendaOriginal = registrarVenda;
        registrarVenda = async function(tipoPagamento, dadosTEF) {
            const resultado = await _registrarVendaOriginal(tipoPagamento, dadosTEF);
            if (resultado && resultado.sucesso) {
                // Monta payload de impressão com os dados do carrinho atual
                const itensParaImprimir = carrinho.map(item => ({
                    nome:           item.nome,
                    quantidade:     item.quantidade,
                    preco_unitario: parseFloat(item.preco)
                }));
                _salvarUltimaVenda({
                    loja:              lojaAtual ? lojaAtual.nome : 'ESTABELECIMENTO',
                    endereco:          lojaAtual ? (lojaAtual.endereco || '') : '',
                    cidade:            lojaAtual ? (lojaAtual.cidade   || '') : '',
                    telefone:          lojaAtual ? (lojaAtual.telefone || '') : '',
                    cnpj:              lojaAtual ? (lojaAtual.cnpj     || '') : '',
                    metodo_pagamento:  tipoPagamento,
                    total:             parseFloat(getValorTotal()),
                    codigo_venda:      resultado.codigo_venda || '',
                    itens:             itensParaImprimir
                });
            }
            return resultado;
        };
    </script>
