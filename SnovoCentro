        function _atualizarTroco() {
            const inputVal = document.getElementById('mdInput').value.replace(',', '.');
            const recebido = parseFloat(inputVal);
            const trocoBox = document.getElementById('mdTrocoBox');
            const trocoValor = document.getElementById('mdTrocoValor');
            const trocoMsg = document.getElementById('mdTrocoMsg');
            const btnOk = document.getElementById('mdBtnOk');

            if (isNaN(recebido) || recebido <= 0) {
                trocoBox.className = 'modal-dinheiro-troco-box';
                trocoValor.className = 'modal-dinheiro-troco-valor';
                trocoValor.textContent = '—';
                trocoMsg.textContent = '';
                btnOk.disabled = true;
                return;
            }

            const troco = recebido - _dinheiroValorTotal;

            if (troco < 0) {
                trocoBox.className = 'modal-dinheiro-troco-box';
                trocoValor.className = 'modal-dinheiro-troco-valor';
                trocoValor.textContent = '— insuficiente';
                trocoMsg.textContent = `Falta R$ ${Math.abs(troco).toFixed(2).replace('.', ',')}`;
                btnOk.disabled = true;
            } else if (troco === 0) {
                trocoBox.className = 'modal-dinheiro-troco-box sem-troco';
                trocoValor.className = 'modal-dinheiro-troco-valor sem-troco';
                trocoValor.textContent = 'Sem troco ✅';
                trocoMsg.textContent = 'Valor exato!';
                btnOk.disabled = false;
            } else {
                trocoBox.className = 'modal-dinheiro-troco-box tem-troco';
                trocoValor.className = 'modal-dinheiro-troco-valor tem-troco';
                trocoValor.textContent = 'R$ ' + troco.toFixed(2).replace('.', ',');
                trocoMsg.textContent = `Recebido: R$ ${recebido.toFixed(2).replace('.', ',')}`;
                btnOk.disabled = false;
            }
        }

