        async function buscarVendasDia() {
            const dataInput = document.getElementById('dataFiltro').value;
            
            if (!dataInput) {
                alert('❌ Selecione uma data');
                return;
            }

            const listaDiv = document.getElementById('listaVendas');
            listaDiv.innerHTML = '<div class="loading-vendas">⏳ Carregando vendas...</div>';

            try {
                // Buscar vendas do dia selecionado
                const dataInicio = inicioDiaBrasilia(dataInput);
                const dataFim    = fimDiaBrasilia(dataInput);

                const { data: vendas, error } = await supabaseClient
                    .from('vendas')
                    .select('*')
                    .eq('loja_id', lojaAtual.id)
                    .gte('data_venda', dataInicio)
                    .lte('data_venda', dataFim)
                    .order('data_venda', { ascending: false });

                if (error) throw error;

                console.log(`✅ ${vendas.length} vendas encontradas`);

                if (vendas.length === 0) {
                    listaDiv.innerHTML = `
                        <div class="empty-vendas">
                            <div class="empty-vendas-icon">📊</div>
                            <p>Nenhuma venda encontrada para ${new Date(dataInput + 'T12:00:00-03:00').toLocaleDateString('pt-BR', { timeZone: 'America/Sao_Paulo' })}</p>
                        </div>
                    `;
                    return;
                }

                // Buscar itens de cada venda
                let html = '';
                for (const venda of vendas) {
                    const { data: itens } = await supabaseClient
                        .from('itens_venda')
                        .select('*')
                        .eq('venda_id', venda.id)
                        .order('nome_produto');

                    html += renderizarVendaCard(venda, itens);
                }

                listaDiv.innerHTML = html;

            } catch (error) {
                console.error('Erro ao buscar vendas:', error);
                listaDiv.innerHTML = `
                    <div class="empty-vendas">
                        <div class="empty-vendas-icon">⚠️</div>
                        <p>Erro ao carregar vendas</p>
                    </div>
                `;
            }
        }

        function renderizarVendaCard(venda, itens) {
            const dataFormatada = formatarDataBrasilia(venda.data_venda);
            const isCancelada = venda.status === 'CANCELADA';
            
            const metodoClass = {
                'PIX': 'metodo-pix',
                'CREDITO': 'metodo-credito',
                'DEBITO': 'metodo-debito',
                'DINHEIRO': 'metodo-dinheiro'
            }[venda.metodo_pagamento] || 'metodo-pix';

            let itensHtml = '';
            itens.forEach(item => {
                itensHtml += `
                    <div class="item-venda">
                        <div>
                            <span class="item-nome">${item.nome_produto}</span>
                            <span class="item-qtd"> x${item.quantidade}</span>
                        </div>
                        <span class="item-preco">R$ ${parseFloat(item.subtotal).toFixed(2)}</span>
                    </div>
                `;
            });

            return `
                <div class="venda-card ${isCancelada ? 'venda-cancelada' : ''}">
                    <div class="venda-header">
                        <div class="venda-info">
                            <div class="venda-id">#${venda.id}</div>
                            <div class="venda-data">📅 ${dataFormatada}</div>
                            <span class="venda-metodo ${metodoClass}">${venda.metodo_pagamento}</span>
                            ${isCancelada ? '<span class="badge-cancelada">❌ CANCELADA</span>' : ''}
                        </div>
                        <div class="venda-total">R$ ${parseFloat(venda.valor_total).toFixed(2)}</div>
                    </div>
                    <div class="venda-itens">
                        <strong style="display: block; margin-bottom: 10px; color: #6b7280;">📦 Itens da Venda:</strong>
                        ${itensHtml}
                    </div>
                    <div class="venda-actions">
                        <button 
                            class="btn-reverter" 
                            onclick="reverterVenda(${venda.id})"
                            ${isCancelada ? 'disabled' : ''}
                        >
                            ↩️ ${isCancelada ? 'JÁ CANCELADA' : 'REVERTER VENDA'}
                        </button>
                    </div>
                </div>
            `;
        }

        async function reverterVenda(vendaId) {
            if (!confirm('⚠️ ATENÇÃO!\n\nReverter esta venda irá:\n\n• Cancelar a venda\n• Devolver produtos ao estoque\n• Impedir contabilização financeira\n\nDeseja continuar?')) {
                return;
            }

            try {
                console.log('Revertendo venda:', vendaId);

                // 1. Buscar itens da venda
                const { data: itens, error: itensError } = await supabaseClient
                    .from('itens_venda')
                    .select('*')
                    .eq('venda_id', vendaId);

                if (itensError) throw itensError;

                console.log('Itens da venda:', itens);

                // 2. Devolver estoque de cada item
                for (const item of itens) {
                    console.log(`Devolvendo ${item.quantidade}x ${item.nome_produto} ao estoque...`);

                    // Buscar estoque atual
                    const { data: itemAtual, error: fetchError } = await supabaseClient
                        .from('itens')
                        .select('estoque')
                        .eq('codigo', item.codigo_produto)
                        .eq('loja_id', lojaAtual.id)
                        .single();

                    if (fetchError) {
                        console.error('Erro ao buscar item:', fetchError);
                        continue;
                    }

                    const novoEstoque = itemAtual.estoque + item.quantidade;

                    // Atualizar estoque
                    const { error: estoqueError } = await supabaseClient
                        .from('itens')
                        .update({ estoque: novoEstoque })
                        .eq('codigo', item.codigo_produto)
                        .eq('loja_id', lojaAtual.id);

                    if (estoqueError) {
                        console.error('Erro ao atualizar estoque:', estoqueError);
                    } else {
                        console.log(`✅ Estoque atualizado: ${item.codigo_produto} (${itemAtual.estoque} → ${novoEstoque})`);
                    }

                    // Registrar movimentação de devolução
                    await supabaseClient
                        .from('movimentacoes')
                        .insert([{
                            loja_id: lojaAtual.id,
                            item_codigo: item.codigo_produto,
                            tipo: 'DEVOLUCAO',
                            quantidade: item.quantidade,
                            valor_unitario: item.preco_unitario,
                            responsavel: usuarioAtual.email,
                            observacao: `Devolução por cancelamento da venda #${vendaId}`
                        }]);
                }

                // 3. Marcar venda como CANCELADA
                const { error: vendaError } = await supabaseClient
                    .from('vendas')
                    .update({ 
                        status: 'CANCELADA',
                        observacao: `CANCELADA em ${formatarDataBrasilia(new Date().toISOString())} por ${usuarioAtual.email}`
                    })
                    .eq('id', vendaId)
                    .eq('loja_id', lojaAtual.id);

                if (vendaError) throw vendaError;

                console.log('✅ Venda cancelada:', vendaId);

                alert('✅ VENDA REVERTIDA COM SUCESSO!\n\n• Estoque devolvido\n• Venda cancelada\n• Não será contabilizada');

                // Recarregar lista de vendas
                buscarVendasDia();

            } catch (error) {
                console.error('❌ Erro ao reverter venda:', error);
                alert('❌ Erro ao reverter venda: ' + error.message);
            }
        }
    </script>

    <!-- ==================== INTEGRAÇÃO PAGBANK (PLUGPAG) ==================== -->
    <script>
        const PAGBANK_URL = 'http://localhost:5000'

        // ==================== ABRIR GAVETA ====================
        async function abrirGaveta() {
            try {
                const _r = await fetch(`${PAGBANK_URL}/abrir-gaveta`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ acao: 'abrir' }),
                    signal: AbortSignal.timeout(5000)
                });
                const _d = await _r.json();
                if (_d.sucesso) return { sucesso: true };
                throw new Error(_d.erro || 'Gaveta nao abriu');
            } catch (e) {
                const ok = confirm('⚠️ ERRO GAVETA\nContinuar SEM gaveta?');
                return { sucesso: false, continuarVenda: ok };
            }
        }

        // ==================== DÉBITO PAGBANK ====================
        async function debito() {
            const valorBruto = getValorTotal() || prompt('Insira um valor em R$ no formato (00.00)', '1.00');
            const valor = parseFloat(valorBruto);
            if (!valor || valor <= 0) return null;

            console.log(`💳 Iniciando DÉBITO PagBank: R$ ${valor.toFixed(2)}`);
            try {
                const resp = await fetch(`${PAGBANK_URL}/pagbank/debito`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ valor })
                });
                const data = await resp.json();
                console.log('PagBank Débito response:', data);

                // Normaliza resposta para o mesmo formato que o restante do sistema espera
                return _normalizarRespostaPagBank(data);
            } catch (err) {
                console.error('Erro PagBank débito:', err);
                return null;
            }
        }

        // ==================== CRÉDITO PAGBANK ====================
        async function credito() {
            const valorBruto = getValorTotal() || prompt('Insira um valor em R$ no formato (00.00)', '1.00');
            const valor = parseFloat(valorBruto);
            if (!valor || valor <= 0) return null;

            console.log(`💳 Iniciando CRÉDITO PagBank: R$ ${valor.toFixed(2)}`);
            try {
                const resp = await fetch(`${PAGBANK_URL}/pagbank/credito`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ valor })
                });
                const data = await resp.json();
                console.log('PagBank Crédito response:', data);

