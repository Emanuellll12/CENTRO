                    .select('id, status')
                    .eq('id', caixaId)
                    .single();

                console.log('🔄 Verificação pós-fechamento:', verificacao);

                if (!verificacao || verificacao.status !== 'FECHADO') {
                    // O update NÃO funcionou! Tentar de novo
                    console.error('❌ ALERTA: Caixa NÃO foi fechado no banco! Status:', verificacao?.status);
                    
                    // Segunda tentativa
