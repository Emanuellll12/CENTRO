                    .from('movimentacoes')
                    .insert([{
                        loja_id: lojaAtual.id,
                        item_codigo: produto.codigo,
                        tipo: 'REPOSICAO',
                        quantidade: qtdReposicao,
                        valor_unitario: produto.preco_venda,
                        responsavel: usuarioAtual.email,
                        observacao: `Reposição manual via PDV`
                    }]);

                if (movError) console.warn('Aviso ao registrar movimentação:', movError);

                console.log('✅ Movimentação registrada');

                // 3. Enviar notificação para Telegram
                await enviarNotificacaoTelegram(produto, qtdReposicao, novoEstoque);

                // 4. Recarregar produtos para atualizar interface
                await carregarProdutos();

                alert(
