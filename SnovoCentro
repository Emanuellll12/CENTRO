        async function salvarConfigImpressora() {
            const nome = document.getElementById('inputNomeImpressora').value.trim();
            const feedback = document.getElementById('configImpressoraFeedback');

            if (!nome) {
                feedback.style.color = '#e74c3c';
                feedback.textContent = '⚠️ Digite ou selecione o nome da impressora.';
                return;
            }

            try {
                const resp = await fetch(`${PAGBANK_URL}/config-impressora`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ nome }),
                    signal: AbortSignal.timeout(5000)
                });
                const data = await resp.json();

                if (data.sucesso) {
                    feedback.style.color = '#28a745';
                    feedback.textContent = `✅ ${data.mensagem}`;
                    setTimeout(() => fecharConfigImpressora(), 1200);
                } else {
                    feedback.style.color = '#e74c3c';
                    feedback.textContent = `❌ ${data.erro}`;
                }
            } catch (e) {
                feedback.style.color = '#e74c3c';
                feedback.textContent = '❌ Servidor offline. Não foi possível salvar.';
            }
