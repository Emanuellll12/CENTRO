        // Verificar status do caixa ao carregar
        async function verificarStatusCaixa() {
            console.log('🔍 Verificando status do caixa...');
            console.log('🏪 Loja ID:', lojaAtual ? lojaAtual.id : 'NÃO DEFINIDA');
            
            if (!lojaAtual || !lojaAtual.id) {
                console.error('❌ lojaAtual não definida, impossível verificar caixa');
                atualizarBotaoCaixa(false);
                return;
